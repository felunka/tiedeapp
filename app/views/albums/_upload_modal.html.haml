#albumPictureUploadModal.modal.fade{ tabindex: '-1', aria: { hidden: 'true' } }
  .modal-dialog.modal-dialog-centered
    .modal-content
      .modal-header
        %h5.modal-title= t('albums.show.upload_pictures')
        %button.btn-close{ aria: { label: t('layouts.navigation.close') }, 'data-bs-dismiss' => 'modal', type: 'button' }
      = simple_form_for @album_picture, url: album_album_pictures_path(@album), method: :post do |f|
        .modal-body
          .mb-3
            = f.label :data, class: 'form-label'
            = f.file_field :data, class: 'form-control', multiple: true, accept: 'image/*', id: 'formFile'
        .modal-footer
          %button.btn.btn-secondary{ 'data-bs-dismiss' => 'modal', type: 'button' }
            = t('helpers.submit.cancel')
          = f.submit t('helpers.submit.create'), class: 'btn btn-primary'