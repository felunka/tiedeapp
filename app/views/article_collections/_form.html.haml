.card.mt-3
  %h5.card-header.d-flex.justify-content-between.align-items-center
    = t('article_collections.form.title')
    .d-flex.gap-2
      - if @article_collection.persisted?
        = button_to article_collection_path(@article_collection), class: 'btn btn-danger', method: :delete do
          = t('helpers.submit.delete')
      = button_to article_collections_path, class: 'btn btn-secondary', method: :get do
        = t('helpers.submit.cancel')

  .card-body
    = simple_form_for @article_collection do |f|
      = f.input :name
      = f.input :description, as: :text
      = f.submit class: 'btn btn-primary mt-2'